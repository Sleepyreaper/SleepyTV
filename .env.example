# Copy to ".env" (same folder as compose.yaml) and fill in YOUR values.
# Do not commit the real .env.

# --- NAS (to mount \\sleepynas\PlexMediaServer into Jellyfin) ---
# Use the NAS IP, not its hostname — the CIFS mount can't resolve "sleepynas".
NAS_HOST=192.168.1.116
NAS_USER=your-nas-username
NAS_PASS=your-nas-password

# --- SleepyTV host port ---
# The container listens on 8080 internally; this is the HOST port you browse to.
# 8080 is already taken on sleepycore — pick a free one. See what's in use with:
#   docker ps --format 'table {{.Names}}\t{{.Ports}}'      (host ports per container)
#   ss -tlnp | grep LISTEN                                  (all listening ports)
# Then browse to  http://sleepytv.sleepycore:<this-port>  (after adding the
# hosts-file entry:  <sleepycore-IP>  sleepytv.sleepycore).
SLEEPYTV_HOST_PORT=8899
